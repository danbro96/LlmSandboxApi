# Copy to deploy/.env on the dedicated sandbox host. compose.yaml reads these.

# REQUIRED: API key clients present in X-API-Key. Generate: openssl rand -hex 32
SANDBOX_API_KEY=REPLACE_ME_64HEX
SANDBOX_API_KEY_NAME=prod

# Image tag to pull. "latest" = main branch; pin to sha-XXXXXXX for reproducible deploys.
IMAGE_TAG=latest

# LAN port the MCP/health surface listens on. Firewall inbound to the assistant host(s) only.
HOST_PORT=8080

# Per-key rate limit (requests/min).
RATE_LIMIT=60

# Container runtime for runs. MUST be 'runsc' (gVisor) in prod — install it on the host first
# (see DevOps/Guides/sandbox-deploy.md). Leave empty ONLY on a dev box without gVisor.
SANDBOX_RUNTIME=runsc

# Per-run resource caps.
SANDBOX_MEMORY_BYTES=268435456
SANDBOX_CPUS=1.0
SANDBOX_PIDS=128
SANDBOX_MAX_CONCURRENT=4
SANDBOX_DEFAULT_TIMEOUT=10
SANDBOX_MAX_TIMEOUT=60

# OpenTelemetry → OpenObserve on MedelyNAS over the LAN (this host is NOT on the medelynas_telemetry
# docker network). Use the LAN IP, not the otel-collector alias. Leave blank to disable.
# Header is "Authorization=Basic <base64 of email:password>".
OTEL_EXPORTER_OTLP_ENDPOINT=http://192.168.14.134:43000/api/default
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,host.name=sandbox-host
