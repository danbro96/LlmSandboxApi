{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "ApiKeys": [
      { "Key": "REPLACE_ME_DEV_ONLY_64HEX", "Name": "default" }
    ],
    "AllowedOrigins": []
  },
  "RateLimit": {
    "RequestsPerMinute": 60
  },
  "Sandbox": {
    "DockerHost": "",
    "Runtime": "",
    "User": "1000:1000",
    "Images": {
      "python": "python:3.12-slim",
      "javascript": "node:22-slim"
    },
    "DefaultTimeoutSeconds": 10,
    "MaxTimeoutSeconds": 60,
    "MemoryBytes": 268435456,
    "Cpus": 1.0,
    "PidsLimit": 128,
    "MaxConcurrent": 4
  },
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:8080" }
    }
  }
}
